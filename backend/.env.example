# Reading ELLA backend local example
# 비워 두면 외부 API는 기본적으로 꺼진 상태로 동작합니다.

READING_ELLA_ENV=development
READING_ELLA_DEBUG=false

# Vercel 프론트나 태블릿 브라우저에서 붙일 때는
# 접속하는 웹 주소를 여기에 넣어야 합니다.
# 예:
# READING_ELLA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://reading-ella.vercel.app

# 필요하면 경로를 바꿀 수 있습니다.
# READING_ELLA_PACKS_DIR=../packs
# READING_ELLA_TRANSLATIONS_DIR=../translations
# READING_ELLA_DATABASE_PATH=backend/data/app.db

# 외부 provider를 비워 두면 외부 호출은 막힙니다.
READING_ELLA_TRANSLATION_PROVIDER=
READING_ELLA_EXPLANATION_PROVIDER=
READING_ELLA_TTS_PROVIDER=

# Gemini를 쓸 때만 넣습니다.
GEMINI_API_KEY=
# READING_ELLA_TRANSLATION_PROVIDER=gemini
# READING_ELLA_EXPLANATION_PROVIDER=gemini
# TTS는 브라우저 기본 음성을 쓰는 것을 권장합니다.
# READING_ELLA_TTS_PROVIDER=

# 2모델 전략
READING_ELLA_ASSIST_MODEL_DEFAULT=gemini-3.1-flash-lite-preview
READING_ELLA_ASSIST_MODEL_DEEP=gemini-2.5-flash

# 외부 TTS를 쓸 때만 참고하는 기본 음성 이름입니다.
READING_ELLA_TTS_VOICE_DEFAULT=alloy

# 개발 테스트용 예시
# READING_ELLA_TRANSLATION_PROVIDER=mock
# READING_ELLA_EXPLANATION_PROVIDER=mock
# READING_ELLA_TTS_PROVIDER=mock
